# ---------------------------------------------------------------------------
# Paper Market World — environment variables
# Copy to `.env.local` and fill in. The admin panel degrades gracefully until
# DATABASE_URL is set (login shows a "not configured" notice; the public site
# works unchanged).
# ---------------------------------------------------------------------------

# Neon Postgres connection string (required for the admin panel).
# Create a free database at https://neon.tech and paste the pooled connection
# string here. Example:
# DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL=

# Initial super-admin created by `npm run db:seed` (only used at seed time).
ADMIN_EMAIL="admin@papermarketworld.com"
ADMIN_PASSWORD="ChangeMe!123"
ADMIN_NAME="Site Administrator"

# Vercel Blob storage token — required for the Media library uploads.
# Get it from the Vercel dashboard → Storage → Blob, or `vercel blob` CLI.
BLOB_READ_WRITE_TOKEN=

# Public site origin (used for canonical + hreflang absolute URLs).
NEXT_PUBLIC_SITE_URL="https://www.papermarketworld.com"

# Contact-form email delivery (optional; the form also stores leads in the DB).
# SENDGRID_API_KEY=
# CONTACT_EMAIL="info@papermarketworld.com"

# ── Bot protection (Cloudflare Turnstile) ──────────────────────────────────
# Optional: when unset, the contact form works with only the honeypot. Create a
# free widget at https://dash.cloudflare.com → Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=

# ── Ad click-fraud protection ──────────────────────────────────────────────
# Secret for the scheduled detection job (/api/cron/click-protection). Vercel
# Cron sends this automatically as a Bearer token when set. Also used to pepper
# hashed IPs in the button-clicks report.
CRON_SECRET=
# IP intelligence provider (datacenter/VPN/proxy detection). Defaults to ip-api
# (free, no key). Set IPINFO_TOKEN to use ipinfo.io instead.
# CLICK_PROTECTION_IP_PROVIDER=ip-api
# IPINFO_TOKEN=
# Your own office/VPN IPs — never logged or scored. Comma-separated.
# CLICK_PROTECTION_INTERNAL_IPS=
